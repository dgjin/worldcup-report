{
  "name": "worldcup-report",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "start": "node dist/server.cjs",
    "snapshot": "node data/build-snapshot.mjs",
    "test": "tsx src/lib/transform.test.ts",
    "lint": "tsc --noEmit",
    "deploy": "vite build && npx wrangler pages deploy dist/client --project-name=worldcup-report --branch=main --commit-dirty=true"
    "pages-dev": "wrangler pages dev dist/client",
    "build:all": "vite build && cp data/snapshot.json dist/client/data/ 2>/dev/null || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.0.0"
  }
}
